    :root{
      --bg:#fff9fd;
      --panel:#ffffff;
      --ink:#4c4a66;
      --muted:#7b7996;
      --pink:#ffd6ea;
      --pink-2:#ffc1dd;
      --lav:#e4dcff;
      --mint:#d9f7ee;
      --peach:#ffe7d6;
      --sky:#dff2ff;
      --yellow:#fff5c8;
      --line:#efe6f6;
      --shadow:0 14px 35px rgba(132, 108, 168, .12);
      --radius:26px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:"Nunito",system-ui,sans-serif;
      color:var(--ink);
      background:
        radial-gradient(circle at top left, #ffe8f4 0%, transparent 24%),
        radial-gradient(circle at top right, #e8f5ff 0%, transparent 24%),
        linear-gradient(180deg, #fffafd 0%, #fffdf7 100%);
    }

    .wrap{
      width:min(1220px, calc(100% - 28px));
      margin:0 auto;
      padding:26px 0 60px;
    }

    .hero{
      position:relative;
      overflow:hidden;
      background:linear-gradient(135deg, #ffe0ef 0%, #e9e1ff 55%, #ddf3ff 100%);
      border:1.5px solid rgba(255,255,255,.75);
      border-radius:34px;
      padding:30px 28px 26px;
      box-shadow:var(--shadow);
    }

    .hero::before,
    .hero::after{
      content:"";
      position:absolute;
      border-radius:50%;
      opacity:.55;
      filter:blur(10px);
      pointer-events:none;
    }

    .hero::before{
      width:210px;height:210px;
      right:-40px; top:-40px;
      background:#fff4c7;
    }

    .hero::after{
      width:160px;height:160px;
      left:-20px; bottom:-30px;
      background:#ffe4f0;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:22px;
      align-items:center;
      position:relative;
      z-index:1;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 14px;
      border-radius:999px;
      background:rgba(255,255,255,.7);
      border:1px solid rgba(255,255,255,.85);
      font-size:.92rem;
      font-weight:800;
      color:#6a5b87;
      letter-spacing:.2px;
    }

    h1{
      font-family:"Quicksand", sans-serif;
      font-size:clamp(2rem, 3vw, 3rem);
      line-height:1.05;
      margin:16px 0 12px;
    }

    .lead{
      font-size:1.05rem;
      line-height:1.55;
      max-width:700px;
      color:#5c5b79;
      margin:0 0 16px;
    }

    .pill-row{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:12px;
    }

    .pill{
      padding:8px 14px;
      background:rgba(255,255,255,.72);
      border:1px solid rgba(255,255,255,.95);
      border-radius:999px;
      font-size:.92rem;
      font-weight:700;
      color:#6a6281;
    }

    .pet-stage{
      background:rgba(255,255,255,.55);
      border:1px solid rgba(255,255,255,.85);
      border-radius:28px;
      padding:18px;
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:250px;
    }

    .toolbar{
      margin:26px 0 18px;
      display:grid;
      grid-template-columns:1fr auto;
      gap:14px;
      align-items:center;
    }

    .searchbox{
      display:flex;
      align-items:center;
      gap:10px;
      background:var(--panel);
      border:1px solid var(--line);
      border-radius:18px;
      padding:12px 16px;
      box-shadow:var(--shadow);
    }

    .searchbox input{
      border:0;
      outline:none;
      width:100%;
      font:inherit;
      color:var(--ink);
      background:transparent;
    }

    .filters{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      justify-content:flex-end;
    }

    .filter-btn{
      border:1px solid var(--line);
      background:#fff;
      color:#6a6582;
      border-radius:999px;
      padding:10px 14px;
      font:700 .92rem "Nunito",sans-serif;
      cursor:pointer;
      transition:.2s ease;
      box-shadow:0 8px 18px rgba(132,108,168,.08);
    }

    .filter-btn.active,
    .filter-btn:hover{
      transform:translateY(-2px);
      background:linear-gradient(135deg, #ffd8ea, #e7e0ff);
      border-color:#ead6f6;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(4, minmax(220px, 1fr));
      gap:18px;
    }

    .card{
      perspective:1200px;
      min-height:390px;
    }

    .card.hide{display:none}

    .card-inner{
      position:relative;
      width:100%;
      height:100%;
      min-height:390px;
      transform-style:preserve-3d;
      transition:transform .8s ease;
    }

    .card:hover .card-inner,
    .card:focus-within .card-inner,
    .card.flipped .card-inner{
      transform:rotateY(180deg);
    }

    .face{
      position:absolute;
      inset:0;
      backface-visibility:hidden;
      border-radius:28px;
      background:var(--panel);
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .front{
      justify-content:space-between;
      padding:18px 18px 16px;
    }

    .back{
      transform:rotateY(180deg);
      padding:18px;
    }

    .tag{
      align-self:flex-start;
      padding:8px 12px;
      border-radius:999px;
      font-size:.82rem;
      font-weight:800;
      letter-spacing:.2px;
      color:#655d7d;
      background:#fff7fb;
      border:1px solid #f3e0ee;
    }

    .art{
      flex:1;
      display:grid;
      place-items:center;
      padding:8px 6px;
    }

    .title{
      text-align:center;
      font-family:"Quicksand", sans-serif;
      font-size:1.26rem;
      font-weight:800;
      line-height:1.15;
      margin:10px 0 6px;
      color:#514d6b;
    }

    .mini{
      text-align:center;
      font-size:.92rem;
      color:var(--muted);
      margin:0;
    }

    .hint{
      margin-top:12px;
      text-align:center;
      font-size:.82rem;
      color:#9a93aa;
    }

    .back h3{
      margin:0 0 12px;
      font-size:1.08rem;
      font-family:"Quicksand",sans-serif;
    }

    .info-list{
      display:grid;
      gap:10px;
    }

    .info{
      background:#fffafb;
      border:1px solid #f2e9f6;
      border-radius:18px;
      padding:10px 12px;
    }

    .info b{
      display:block;
      font-size:.84rem;
      color:#8a7aa9;
      margin-bottom:3px;
      text-transform:uppercase;
      letter-spacing:.35px;
    }

    .info span{
      display:block;
      line-height:1.42;
      font-size:.94rem;
      color:#564f6d;
    }

    .legend{
      margin-top:26px;
      background:#ffffffcc;
      border:1px solid var(--line);
      border-radius:24px;
      padding:20px;
      box-shadow:var(--shadow);
    }

    .legend h2,
    .sources h2{
      margin:0 0 14px;
      font-size:1.2rem;
      font-family:"Quicksand", sans-serif;
    }

    .legend-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:12px;
    }

    .legend-item{
      border-radius:18px;
      padding:14px;
      background:#fff;
      border:1px solid var(--line);
    }

    .legend-item strong{display:block; margin-bottom:6px}
    .sources{
      margin-top:18px;
      background:#fff;
      border:1px solid var(--line);
      border-radius:24px;
      padding:20px;
      box-shadow:var(--shadow);
    }

    .sources ul{
      margin:0;
      padding-left:18px;
      line-height:1.6;
      color:#5d5774;
    }

    .sources a{
      color:#7b5cb1;
      text-decoration:none;
    }

    .footer{
      margin-top:24px;
      text-align:center;
      color:#847f98;
      font-weight:700;
      font-size:.95rem;
    }

    .sr-only{
      position:absolute;
      width:1px;height:1px;
      padding:0;margin:-1px;
      overflow:hidden;clip:rect(0,0,0,0);border:0;
    }

    @media (max-width: 1040px){
      .cards{grid-template-columns:repeat(3,minmax(220px,1fr));}
      .legend-grid{grid-template-columns:repeat(2,1fr)}
      .hero-grid{grid-template-columns:1fr}
      .pet-stage{min-height:190px}
    }

    @media (max-width: 760px){
      .wrap{width:min(100% - 16px, 100%)}
      .toolbar{grid-template-columns:1fr}
      .filters{justify-content:flex-start}
      .cards{grid-template-columns:repeat(2,minmax(160px,1fr));}
      .card,.card-inner{min-height:410px}
    }

    @media (max-width: 520px){
      .cards{grid-template-columns:1fr;}
      .legend-grid{grid-template-columns:1fr}
      .hero{padding:22px 18px}
    }
  </style>
</head>
